# ────────────────────────────────────────────────────────────────────────
# BMX Start Analyzer — variables d'environnement de prod.
# Copier en .env (NE PAS COMMIT) et remplir les valeurs.
# ────────────────────────────────────────────────────────────────────────

# Domaine sur lequel l'app est accessible.
# Ex: bmx-louis.duckdns.org (gratuit) ou bmxstart.ca (acheté)
DOMAIN=bmx-louis.duckdns.org

# E-mail pour les notifs Let's Encrypt (optionnel mais conseillé).
ACME_EMAIL=ton-email@example.com

# Identifiants pour l'accès web (HTTP Basic Auth).
# Le hash se génère avec :
#   docker run --rm caddy:2 caddy hash-password --plaintext 'TonMotDePasse'
# Copie le hash COMPLET ci-dessous (commence par $2a$ ou $2b$).
BASIC_AUTH_USER=louis
BASIC_AUTH_HASH=$2a$14$REMPLACE_MOI_PAR_LE_VRAI_HASH
